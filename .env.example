# BambuBabu configuration. Copy to .env and keep chmod 600.

APP_NAME=BambuBabu
DEBUG=false
HOST=127.0.0.1
PORT=8000
# Keep empty for same-origin only. Never use *.
CORS_ORIGINS=
AUTHENTICATION_MODE=external-pending

# Runtime data lives outside the read-only application checkout on the Pi.
UPLOAD_DIR=/var/lib/bambubabu/uploads
SLICED_DIR=/var/lib/bambubabu/sliced
LOG_DIR=/var/lib/bambubabu/logs
DB_PATH=/var/lib/bambubabu/bambubabu.db
DB_BACKUP_DIR=/var/lib/bambubabu/backups

# Live printer mode fails startup until every value below is replaced.
PRINTERS_ENABLED=true
P1S_IP=replace_me
P1S_SERIAL=replace_me
P1S_ACCESS_CODE=replace_me
P1S_MQTT_CERT_PATH=/var/lib/bambubabu/certs/p1s-mqtt.pem
P1S_FTPS_PIN=replace_me
A1_MINI_IP=replace_me
A1_MINI_SERIAL=replace_me
A1_MINI_ACCESS_CODE=replace_me
A1_MINI_MQTT_CERT_PATH=/var/lib/bambubabu/certs/a1-mini-mqtt.pem
A1_MINI_FTPS_PIN=replace_me
MQTT_PUBLISH_TIMEOUT_SECONDS=10
PRINT_START_CONFIRM_TIMEOUT_SECONDS=60

# Optional email. Leave SMTP_PASSWORD empty to disable mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=

# Installed by scripts/install_pi.sh.
ORCA_SLICER_PATH=/opt/bambubabu/orca/appimage-root/AppRun
SLICER_PROFILES_DIR=/opt/bambubabu/orca/appimage-root/resources/profiles/BBL
MOCK_SLICER=false

COMPLEXITY_THRESHOLD=50
MAX_STL_SIZE_MB=100
MAX_ACTIVE_JOBS=50
MAX_STORAGE_MB=2048
MAX_CONCURRENT_JOBS=2
QUEUE_POLL_INTERVAL_SECONDS=10
TERMINAL_FILE_RETENTION_DAYS=30
PARTIAL_UPLOAD_RETENTION_HOURS=1
ORPHAN_FILE_RETENTION_HOURS=24
MAINTENANCE_INTERVAL_SECONDS=3600
DB_BACKUP_INTERVAL_HOURS=24
DB_BACKUP_KEEP=14
