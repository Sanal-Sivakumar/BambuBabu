# App
APP_NAME=BambuBabu
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Bambu Lab P1S ──────────────────────────
P1S_IP=192.168.10.116
P1S_SERIAL=01P09C552500636
P1S_ACCESS_CODE=dd4b4e51

# ── Bambu Lab A1 Mini ──────────────────────
A1_MINI_IP=192.168.10.115
A1_MINI_SERIAL=0300DA610705389
A1_MINI_ACCESS_CODE=c9fd869a

# ── Email (Gmail) ──────────────────────────
# To get Gmail app password:
#   1. Enable 2FA on your Google account
#   2. Go to: Google Account > Security > App Passwords
#   3. Create a new app password and paste it below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sanalsiva2005@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ADMIN_EMAIL=sanalsiva2005@gmail.com

# ── Slicer ─────────────────────────────────
# Path to OrcaSlicer binary on the Pi
# After install, run: which OrcaSlicer
ORCA_SLICER_PATH=/usr/bin/OrcaSlicer
# Set to true to skip slicing (for testing without OrcaSlicer)
MOCK_SLICER=false

# ── Queue ──────────────────────────────────
COMPLEXITY_THRESHOLD=50
MAX_STL_SIZE_MB=100
MAX_CONCURRENT_JOBS=2
QUEUE_POLL_INTERVAL_SECONDS=10
